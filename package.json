{
  "name": "faizan-portfolio",
  "version": "2.0.0",
  "description": "Faizan Khalid - Full Stack Developer Portfolio",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./assets/css/tailwind.css --minify",
    "build:public": "node ./scripts/prepare-public.mjs",
    "build": "npm run build:css && npm run build:public",
    "watch": "tailwindcss -i ./src/input.css -o ./assets/css/tailwind.css --watch",
    "start": "npm run build:css && npx serve -l 3000",
    "dev": "npm run build:css && npx serve -l 3000"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "tailwindcss": "^4.1.11"
  }
}
